{
  "name": "irwfs-desktop",
  "version": "1.0.0",
  "description": "IrwFS Face Swap Desktop Application",
  "main": "main.js",
  "homepage": "https://irwfs.com",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux AppImage",
    "build:mac": "electron-builder --mac",
    "pack": "electron-builder --dir"
  },
  "author": {
    "name": "IrwFS Team",
    "email": "support@irwfs.com"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "form-data": "^4.0.0"
  },
  "build": {
    "appId": "com.irwfs.desktop",
    "productName": "IrwFS Face Swap",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Graphics"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.graphics-design"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
