# IrwFS Environment Configuration

# Database
DATABASE_URL=postgresql+asyncpg://your_db_user:your_db_password@localhost:5432/irwfs
DATABASE_URL_SYNC=postgresql://your_db_user:your_db_password@localhost:5432/irwfs

# JWT Settings
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Tencent Cloud Storage
TENCENT_SECRET_ID=YOUR_TENCENT_SECRET_ID
TENCENT_SECRET_KEY=YOUR_TENCENT_SECRET_KEY
TENCENT_BUCKET=your-bucket-name
TENCENT_REGION=ap-jakarta

# Email Settings (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@irwfs.com

# App Settings
APP_NAME=IrwFS
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# GPU Settings
USE_GPU=True
ONNX_PROVIDER=CUDAExecutionProvider

# Quota Settings
FREE_USER_VIDEO_QUOTA=3
FREE_USER_IMAGE_QUOTA=10

# Admin Settings
SUPERADMIN_EMAIL=admin@irwfs.com
SUPERADMIN_PASSWORD=change_this_password
